HOST=localhost
PORT=3000

MONGODB_URI=mongodb://localhost:27017/board

JWT_SECRET=your_jwt_secret_here

# Mail driver: smtp | resend
MAIL_DRIVER=smtp
MAIL_FROM_NAME=My App
MAIL_FROM_EMAIL=noreply@example.com

# SMTP configuration (used when MAIL_DRIVER=smtp)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password

# Resend configuration (used when MAIL_DRIVER=resend)
RESEND_API_KEY=re_your_api_key_here

# Base URL used in reset email links (no trailing slash)
APP_URL=http://localhost:3000
