### 

@baseUrl = http://localhost:4000
@postId = REPLACE_WITH_POST_ID
@token = REPLACE_WITH_TOKEN_FROM_LOGIN


### 1) Create post — success (201)

POST {{baseUrl}}/posts HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "body": "This is the post body.",
  "title": "My First Post"
}


### 2) Create post — missing body field (400)

POST {{baseUrl}}/posts HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "No Body Post"
}


### 3) Create post — missing title (400)

POST {{baseUrl}}/posts HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "body": "No title here."
}


### 4) Create post — no token (401)

POST {{baseUrl}}/posts HTTP/1.1
Content-Type: application/json

{
  "body": "Should be rejected.",
  "title": "Unauthorized Post"
}


### 5) List all posts — success (200)

GET {{baseUrl}}/posts HTTP/1.1


### 6) Get post by ID — success (200)

GET {{baseUrl}}/posts/{{postId}} HTTP/1.1


### 7) Get post by ID — not found (404)

GET {{baseUrl}}/posts/000000000000000000000000 HTTP/1.1


### 8) Get post by ID — invalid ID format (400)

GET {{baseUrl}}/posts/invalid-id HTTP/1.1


### 9) Update post — success (200)

PUT {{baseUrl}}/posts/{{postId}} HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "body": "Updated body content.",
  "title": "Updated Title"
}


### 10) Update post — not owner (403)

PUT {{baseUrl}}/posts/{{postId}} HTTP/1.1
Content-Type: application/json
Authorization: Bearer REPLACE_WITH_OTHER_USER_TOKEN

{
  "title": "Should be forbidden"
}


### 11) Update post — not found (404)

PUT {{baseUrl}}/posts/000000000000000000000000 HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "Ghost post"
}


### 12) Update post — no token (401)

PUT {{baseUrl}}/posts/{{postId}} HTTP/1.1
Content-Type: application/json

{
  "title": "No auth"
}


### 13) Delete post — success (200)

DELETE {{baseUrl}}/posts/{{postId}} HTTP/1.1
Authorization: Bearer {{token}}


### 14) Delete post — not owner (403)

DELETE {{baseUrl}}/posts/{{postId}} HTTP/1.1
Authorization: Bearer REPLACE_WITH_OTHER_USER_TOKEN


### 15) Delete post — not found (404)

DELETE {{baseUrl}}/posts/000000000000000000000000 HTTP/1.1
Authorization: Bearer {{token}}


### 16) Delete post — no token (401)

DELETE {{baseUrl}}/posts/{{postId}} HTTP/1.1
